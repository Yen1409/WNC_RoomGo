
<div class="auth-card">
    <h1 class="h3">Quên mật khẩu</h1>
    <p class="text-muted">Vui lòng nhập đầy đủ thông tin bên dưới.</p>

    <form method="post">

       
        <div class="mb-3">
            <label for="email" class="form-label"></label>
            <input type="email" name="email" class="form-control" placeholder="ten@example.com" autocomplete="email" />
            
        </div>

       

        <button type="submit" class="btn btn-primary w-100">Lấy lại mật khẩu</button>
    </form>
</div>

<partial name="_AccountValidationScripts" />
