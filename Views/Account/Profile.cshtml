@model RoomGoHanoi.ViewModels.EditProfileVm
@using RoomGoHanoi.Helpers

<div class="container py-5" style="max-width:800px;margin:auto">
    <h1 class="h3 mb-4">Hồ sơ cá nhân</h1>

    @if (TempData["Success"] != null)
    {
    <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card card-body">
        <form asp-action="Profile" method="post" enctype="multipart/form-data" novalidate>
            <div class="row g-3">
                <div class="col-md-4 text-center">
                    @{
                        var avatarUrl = ImageUrlHelper.ResolveUrl(Context, Model?.AvatarUrl);
                    }
                    <img src="@avatarUrl" class="rounded-circle mb-3" style="width:140px;height:140px;object-fit:cover" alt="Avatar" />
                    <div class="mb-2">
                        <label class="form-label">Thay ảnh đại diện</label>
                        <input type="file" name="avatar" accept="image/*" class="form-control form-control-sm" />
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_AccountValidationScripts" />
}