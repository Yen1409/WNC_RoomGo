@model AppUser
<h1 class="h3">Xác thực để trở thành Chủ trọ</h1>
<div class="card card-body col-md-6">
    <p>Nhập số điện thoại, sau đó nhập OTP. Phiên bản bài tập dùng OTP demo: <b>123456</b>.</p>
    <form method="post"><input name="phone" value="@Model?.Phone" class="form-control mb-2" placeholder="Số điện thoại"
            required /><input name="otp" class="form-control mb-2" placeholder="Mã OTP" required /><button
            class="btn btn-primary">Xác thực & nâng cấp</button></form>
</div>
