@model AppUser
<div class="d-flex justify-content-center" style="margin-bottom: 20px;max-width: 800px; margin: 50px auto;">
    <div class="card card-body col-md-6 text-center">
        @if (Model?.Role == UserRole.Owner || Model?.Role == UserRole.Admin)
        {
            <h1 class="h3">Bạn đã là Chủ trọ</h1>
            <p class="text-success">Tài khoản của bạn đã có quyền Chủ trọ hoặc Admin, nên không cần xác thực OTP nữa.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Quay về trang chủ</a>
        }
        else
        {
            <h1 class="h3">Xác thực để trở thành Chủ trọ</h1>
            <p>Nhập số điện thoại, sau đó nhập OTP. Phiên bản bài tập dùng OTP demo: <b>123456</b>.</p>
            <form method="post" class="col-md-4 mx-auto">
                <input name="phone" value="@Model?.Phone" class="form-control mb-2" placeholder="Số điện thoại" required />
                <input name="otp" class="form-control mb-2" placeholder="Mã OTP" required />
                <button class="btn btn-primary w-100">Xác thực & nâng cấp</button>
            </form>
        }
    </div>
</div>
