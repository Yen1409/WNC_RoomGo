@model IEnumerable<Listing>
@{
    ViewData["Title"] = "Tìm phòng trọ thông minh";
}

<section class="hero-home">
    <div class="hero-copy">
        <span class="eyebrow">TÌM PHÒNG THÔNG MINH TẠI HÀ NỘI</span>
        <h1>Chạm đúng nơi ở<br />hợp với bạn.</h1>
        <p>Hàng nghìn phòng trọ đã kiểm duyệt, chủ trọ xác thực và tìm kiếm trực quan theo vị trí.</p>
        <form method="get" asp-controller="Home" asp-action="Search" class="hero-search">
            <input name="Keyword" placeholder="Tên đường, trường học, từ khóa..." />
            <button>Tìm phòng <span>→</span></button>
        </form>
    </div>
    <div class="hero-photo-wrap">
        <img src="https://i.pinimg.com/736x/35/f7/42/35f742dea62ea179a89902ed56ba7a0c.jpg" alt="Không gian phòng trọ hiện đại, sáng và gọn gàng" />
    </div>
</section>

<section class="listing-section">
    <div class="section-heading">
        <div>
            <span class="eyebrow">KHÁM PHÁ</span>
            <h2>Phòng trọ mới nhất</h2>
        </div>
        <a asp-action="Search">Xem trên bản đồ →</a>
    </div>
    <div class="row g-4">
        @foreach (var room in Model)
        {
            var imageUrl = "/images/rooms/default-room.svg";
            if (room.Images != null && room.Images.Count > 0)
            {
                var firstImage = room.Images.FirstOrDefault();
                if (firstImage != null && !string.IsNullOrEmpty(firstImage.Url))
                {
                    imageUrl = firstImage.Url.StartsWith("/") 
                        ? firstImage.Url 
                        : $"/{firstImage.Url.TrimStart('~', '/')}";
                }
            }
            
            <div class="col-12 col-sm-6 col-lg-3">
                <article class="room-card h-100">
                    <div class="room-image">
                        <img src="@imageUrl" alt="@room.Title" 
                             onerror="this.onerror=null; this.src='/images/rooms/default-room.svg'" />
                        <span>Đã xác thực</span>
                    </div>
                    <div class="room-content">
                        <p class="room-location">@room.District</p>
                        <h3>@room.Title</h3>
                        <p class="room-address">@room.Address</p>
                        <div class="room-meta">
                            <strong>@room.Price.ToString("N0") đ</strong>
                            <small>@room.Area m²</small>
                        </div>
                    </div>
                    <a class="stretched-link" asp-action="Detail" asp-route-id="@room.Id"
                       aria-label="Xem @room.Title"></a>
                </article>
            </div>
        }
    </div>
    <div class="text-center mt-5">
        <a asp-action="Search" class="view-all">Xem tất cả phòng <span>→</span></a>
    </div>
</section>