@model Listing
@{
    ViewData["Title"] = "Đăng tin cho thuê";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h1 class="h3 mb-2">📝 Đăng tin cho thuê</h1>
                    <p class="text-muted mb-4">
                        <i class="bi bi-info-circle"></i> Chỉ cần nhập địa chỉ đầy đủ; RoomGo sẽ tự xác định vị trí phòng trên bản đồ.
                    </p>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="DangTin" method="post" class="row g-3" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Tiêu đề -->
                        <div class="col-md-12">
                            <label asp-for="Title" class="form-label fw-semibold">
                                <i class="bi bi-tag"></i> @Html.DisplayNameFor(m => m.Title)
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Title" class="form-control" placeholder="Ví dụ: Phòng trọ khép kín full nội thất gần ĐH Bách Khoa" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <!-- Địa chỉ -->
                        <div class="col-md-8">
                            <label asp-for="Address" class="form-label fw-semibold">
                                <i class="bi bi-geo-alt"></i> Địa chỉ chi tiết
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Address" class="form-control" placeholder="Ví dụ: 45 Đại Cồ Việt, phường Bách Khoa" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <!-- Quận/Huyện -->
                        <div class="col-md-4">
                            <label asp-for="District" class="form-label fw-semibold">
                                <i class="bi bi-building"></i> Quận / huyện
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="District" class="form-control" placeholder="Ví dụ: Hai Bà Trưng" />
                            <span asp-validation-for="District" class="text-danger"></span>
                        </div>

                        <!-- Giá -->
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label fw-semibold">
                                <i class="bi bi-currency-dollar"></i> @Html.DisplayNameFor(m => m.Price)
                                <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input asp-for="Price" class="form-control" placeholder="Giá thuê" />
                                <span class="input-group-text">đ/tháng</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <!-- Diện tích -->
                        <div class="col-md-4">
                            <label asp-for="Area" class="form-label fw-semibold">
                                <i class="bi bi-aspect-ratio"></i> @Html.DisplayNameFor(m => m.Area)
                                <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input asp-for="Area" class="form-control" placeholder="Diện tích" />
                                <span class="input-group-text">m²</span>
                            </div>
                            <span asp-validation-for="Area" class="text-danger"></span>
                        </div>

                        <!-- Tiện ích -->
                        <div class="col-md-12">
                            <label asp-for="Amenities" class="form-label fw-semibold">
                                <i class="bi bi-list-check"></i> @Html.DisplayNameFor(m => m.Amenities)
                            </label>
                            <input asp-for="Amenities" class="form-control" placeholder="Điều hòa, nóng lạnh, thang máy, wifi, chỗ để xe..." />
                            <small class="text-muted">Nhập các tiện ích cách nhau bằng dấu phẩy (,)</small>
                            <span asp-validation-for="Amenities" class="text-danger"></span>
                        </div>

                        <!-- Mô tả -->
                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-semibold">
                                <i class="bi bi-file-text"></i> Mô tả chi tiết
                                <span class="text-danger">*</span>
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="6"
                                placeholder="Mô tả không gian phòng, nội thất, an ninh, giờ giấc, chi phí phát sinh và tiện ích xung quanh..."></textarea>
                            <div class="text-end">
                                <small class="text-muted" id="charCount">0 / 2000 ký tự</small>
                            </div>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <!-- Upload ảnh -->
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-images"></i> Hình ảnh phòng
                            </label>
                            <div class="drop-zone" id="dropZone">
                                <div class="drop-zone-content">
                                    <i class="bi bi-cloud-arrow-up display-4"></i>
                                    <p class="mb-1">Kéo thả ảnh vào đây hoặc nhấn để chọn</p>
                                    <small class="text-muted">Hỗ trợ JPG, PNG, GIF (Tối đa 5MB mỗi ảnh)</small>
                                </div>
                                <input type="file" name="images" class="form-control d-none" multiple accept="image/*" id="fileInput" />
                            </div>
                            <div id="previewContainer" class="row g-2 mt-2">
                                <!-- Hiển thị ảnh đã chọn trước đó nếu có lỗi -->
                                @if (TempData["ImagesData"] is List<string> imageDataList && imageDataList.Count > 0)
                                {
                                    @foreach (var base64 in imageDataList)
                                    {
                                        <div class="col-auto">
                                            <div class="preview-item">
                                                <img src="data:image/jpeg;base64,@base64" alt="Preview" />
                                                <button type="button" class="remove-btn" onclick="this.closest('.col-auto').remove()">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                            <input type="hidden" id="imageCount" name="imageCount" value="@(TempData["ImageCount"] ?? 0)" />
                        </div>

                        <!-- Nút submit -->
                        <div class="col-12 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg px-5" id="submitBtn">
                                <i class="bi bi-send"></i> Gửi duyệt tin
                            </button>
                            <a asp-action="Mine" class="btn btn-outline-secondary btn-lg px-4">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        /* CSS giữ nguyên */
        .drop-zone {
            border: 2px dashed #dee2e6;
            border-radius: 10px;
            padding: 30px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            background-color: #f8f9fa;
        }

        .drop-zone:hover,
        .drop-zone.dragover {
            border-color: #0d6efd;
            background-color: #e7f1ff;
        }

        .drop-zone-content i {
            color: #6c757d;
        }

        .drop-zone.dragover .drop-zone-content i {
            color: #0d6efd;
        }

        .preview-item {
            position: relative;
            width: 150px;
            height: 150px;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #dee2e6;
        }

        .preview-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .preview-item .remove-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(255, 0, 0, 0.8);
            color: white;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

        .preview-item .remove-btn:hover {
            background: red;
            transform: scale(1.1);
        }

        .preview-item .file-name {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 5px;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            font-size: 11px;
            text-align: center;
            overflow: hidden;
            white-space: nowrap;
            text-overflow: ellipsis;
        }
    </style>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    
    <script>
        // Đếm số ký tự trong Description
        document.addEventListener('DOMContentLoaded', function() {
            const description = document.querySelector('#Description');
            const charCount = document.querySelector('#charCount');
            
            if (description && charCount) {
                description.addEventListener('input', function() {
                    const count = this.value.length;
                    charCount.textContent = `${count} / 2000 ký tự`;
                    
                    if (count > 1800) {
                        charCount.style.color = count > 1900 ? 'red' : 'orange';
                    } else {
                        charCount.style.color = 'inherit';
                    }
                });
            }
        });

        // Drag and Drop upload ảnh
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const previewContainer = document.getElementById('previewContainer');
        const files = [];

        // Nếu có ảnh từ TempData, thêm vào files
        @if (TempData["ImageCount"] is int imgCount && imgCount > 0)
        {
            <text>
            // Đánh dấu đã có ảnh từ TempData
            </text>
        }

        dropZone.addEventListener('click', () => fileInput.click());

        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('dragover');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('dragover');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            
            if (e.dataTransfer.files.length > 0) {
                handleFiles(e.dataTransfer.files);
            }
        });

        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleFiles(e.target.files);
            }
        });

        function handleFiles(fileList) {
            const maxSize = 5 * 1024 * 1024; // 5MB
            
            for (let i = 0; i < fileList.length; i++) {
                const file = fileList[i];
                
                if (file.size > maxSize) {
                    alert(`File "${file.name}" vượt quá 5MB. Vui lòng chọn file nhỏ hơn.`);
                    continue;
                }
                
                if (!file.type.startsWith('image/')) {
                    alert(`File "${file.name}" không phải là hình ảnh.`);
                    continue;
                }
                
                files.push(file);
                displayPreview(file);
            }
            
            fileInput.value = '';
        }

        function displayPreview(file) {
            const reader = new FileReader();
            reader.onload = (e) => {
                const col = document.createElement('div');
                col.className = 'col-auto';
                
                col.innerHTML = `
                    <div class="preview-item">
                        <img src="${e.target.result}" alt="${file.name}" />
                        <button type="button" class="remove-btn" onclick="removeFile('${file.name}')">
                            <i class="bi bi-x"></i>
                        </button>
                        <div class="file-name">${file.name}</div>
                    </div>
                `;
                
                previewContainer.appendChild(col);
            };
            reader.readAsDataURL(file);
        }

        function removeFile(fileName) {
            const index = files.findIndex(f => f.name === fileName);
            if (index > -1) {
                files.splice(index, 1);
                
                const items = previewContainer.querySelectorAll('.preview-item');
                for (let i = 0; i < items.length; i++) {
                    const nameElement = items[i].querySelector('.file-name');
                    if (nameElement && nameElement.textContent === fileName) {
                        items[i].parentElement.remove();
                        break;
                    }
                }
            }
        }

        // Disable submit button sau khi click
        document.querySelector('form').addEventListener('submit', function() {
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Đang gửi...';
        });
    </script>
}