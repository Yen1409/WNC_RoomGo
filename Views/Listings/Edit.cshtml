@model Listing
@{
    ViewData["Title"] = "Sửa tin đăng";
}

<div class="container py-4">
    <h1 class="h3">✏️ Sửa tin đăng</h1>
    <p class="text-muted">Cập nhật thông tin tin đăng của bạn. Sau khi sửa, tin sẽ được gửi lại để duyệt.</p>

    <div id="notification-area"></div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @success
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="post" class="row g-3" enctype="multipart/form-data" id="editForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="OwnerId" />
        <input type="hidden" asp-for="Latitude" />
        <input type="hidden" asp-for="Longitude" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="Status" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-6">
            <label asp-for="Title" class="form-label fw-semibold"></label>
            <input asp-for="Title" class="form-control" placeholder="Ví dụ: Phòng trọ khép kín full nội thất" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Address" class="form-label fw-semibold">Địa chỉ chi tiết</label>
            <input asp-for="Address" class="form-control" placeholder="Ví dụ: 45 Đại Cồ Việt" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="District" class="form-label fw-semibold">Quận / huyện</label>
            <input asp-for="District" class="form-control" placeholder="Ví dụ: Hai Bà Trưng" />
            <span asp-validation-for="District" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Price" class="form-label fw-semibold"></label>
            <input name="Price" id="Price" class="form-control" type="text" inputmode="numeric" pattern="[0-9.,]+" placeholder="Ví dụ: 2500000" value="@Model.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Area" class="form-label fw-semibold"></label>
            <input asp-for="Area" class="form-control" placeholder="Diện tích (m²)" />
            <span asp-validation-for="Area" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="Amenities" class="form-label fw-semibold"></label>
            <input asp-for="Amenities" class="form-control" placeholder="Điều hòa, nóng lạnh, thang máy..." />
            <span asp-validation-for="Amenities" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="Description" class="form-label fw-semibold">Mô tả chi tiết</label>
            <textarea asp-for="Description" class="form-control" rows="6"
                placeholder="Mô tả không gian phòng, nội thất, an ninh, giờ giấc, chi phí phát sinh và tiện ích xung quanh."></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label class="form-label fw-semibold">Hình ảnh hiện tại</label>
            <div class="row g-2" id="imageGallery">
                @if (Model.Images != null && Model.Images.Any())
                {
                    @foreach (var img in Model.Images)
                    {
                        <div class="col-3" id="image-@img.Id">
                            <div class="position-relative">
                                <img src="@ImageUrlHelper.ResolveUrl(Context, img.Url)" class="w-100 rounded" style="height: 100px; object-fit: cover;" alt="Ảnh phòng" />
                                <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1" 
                                        onclick="deleteImage(@img.Id)" title="Xóa ảnh">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-muted" id="noImages">Chưa có ảnh nào</div>
                }
            </div>
        </div>

        <div class="col-12">
            <label class="form-label fw-semibold">Thêm ảnh mới</label>
            <input type="file" name="images" class="form-control" multiple accept="image/*" id="imageInput" />
            <small class="text-muted">Có thể chọn nhiều ảnh (JPEG, PNG, GIF, WEBP) - Tối đa 5MB mỗi ảnh</small>
            <div class="row g-2 mt-2" id="newImagePreview"></div>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary" id="submitBtn">
                <i class="bi bi-save"></i> Cập nhật
            </button>
            <a asp-action="Mine" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css">
    <style>
        .preview-item {
            position: relative;
            width: 150px;
            height: 150px;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #dee2e6;
        }
        .preview-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .preview-item .remove-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(255, 0, 0, 0.8);
            color: white;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }
        .preview-item .remove-btn:hover {
            background: red;
            transform: scale(1.1);
        }
        .preview-item .file-name {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 5px;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            font-size: 11px;
            text-align: center;
            overflow: hidden;
            white-space: nowrap;
            text-overflow: ellipsis;
        }
    </style>
}

@section Scripts {
    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        // 1. PREVIEW ẢNH MỚI
        document.getElementById('imageInput').addEventListener('change', function(e) {
            const previewContainer = document.getElementById('newImagePreview');
            previewContainer.innerHTML = '';
            
            for (let i = 0; i < this.files.length; i++) {
                const file = this.files[i];
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    const col = document.createElement('div');
                    col.className = 'col-3';
                    col.innerHTML = `
                        <div class="preview-item">
                            <img src="${e.target.result}" alt="${file.name}" />
                            <div class="file-name">${file.name}</div>
                        </div>
                    `;
                    previewContainer.appendChild(col);
                };
                reader.readAsDataURL(file);
            }
        });

        // 2. XÓA ẢNH - SweetAlert2 + AJAX
        function deleteImage(imageId) {
            Swal.fire({
                title: 'Xác nhận xóa ảnh',
                html: `
                    <p style="font-size: 16px; color: #555;">
                        Bạn có chắc chắn muốn xóa ảnh này?
                    </p>
                    <p style="font-size: 14px; color: #dc3545; font-weight: bold;">
                        Hành động này không thể hoàn tác!
                    </p>
                `,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Xóa ảnh',
                cancelButtonText: 'Hủy bỏ',
                reverseButtons: true,
                showLoaderOnConfirm: true,
                allowOutsideClick: () => !Swal.isLoading(),
                preConfirm: () => {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]');
                    const tokenValue = token ? token.value : '';

                    return fetch(`/Listings/DeleteImage/${imageId}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': tokenValue
                        },
                        credentials: 'same-origin'
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (!data.success) {
                            throw new Error(data.message || 'Có lỗi xảy ra khi xóa ảnh!');
                        }
                        return data;
                    })
                    .catch(error => {
                        Swal.showValidationMessage(error.message);
                        throw error;
                    });
                }
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    const data = result.value;
                    const imageElement = document.getElementById(`image-${imageId}`);
                    if (imageElement) {
                        imageElement.style.transition = 'opacity 0.5s, transform 0.3s';
                        imageElement.style.transform = 'scale(0.8)';
                        imageElement.style.opacity = '0';
                        setTimeout(() => {
                            imageElement.remove();
                            // Kiểm tra nếu không còn ảnh nào
                            const gallery = document.getElementById('imageGallery');
                            if (gallery.children.length === 0) {
                                gallery.innerHTML = '<div class="col-12 text-muted">Chưa có ảnh nào</div>';
                            }
                            showToast(data.message || 'Đã xóa ảnh thành công!', 'success');
                        }, 400);
                    } else {
                        location.reload();
                    }
                }
            });
        }

        // 3. HIỂN THỊ TOAST THÔNG BÁO
        function showToast(message, type = 'success') {
            const colors = {
                success: '#28a745',
                danger: '#dc3545',
                warning: '#ffc107',
                info: '#17a2b8'
            };
            
            const toast = document.createElement('div');
            toast.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            toast.style.cssText = `
                top: 20px;
                right: 20px;
                z-index: 9999;
                min-width: 300px;
                max-width: 500px;
                box-shadow: 0 4px 6px rgba(0,0,0,0.1);
                border-left: 4px solid ${colors[type] || '#28a745'};
            `;
            toast.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            `;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.style.transition = 'opacity 0.5s';
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 500);
            }, 5000);
        }

        // 4. DISABLE SUBMIT BUTTON KHI CLICK
        document.querySelector('form').addEventListener('submit', function() {
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Đang xử lý...';
            
            Swal.fire({
                title: '⏳ Đang cập nhật...',
                text: 'Vui lòng đợi trong giây lát.',
                allowOutsideClick: false,
                allowEscapeKey: false,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });
        });

        // 5. KIỂM TRA KHI CÓ LỖI TỪ SERVER
        @if (TempData["Error"] != null)
        {
            <text>
            Swal.fire({
                icon: 'error',
                title: 'Có lỗi xảy ra',
                text: '@TempData["Error"]',
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Đóng'
            });
            </text>
        }

        @if (TempData["Success"] != null)
        {
            <text>
            Swal.fire({
                icon: 'success',
                title: 'Thành công!',
                text: '@TempData["Success"]',
                confirmButtonColor: '#28a745',
                confirmButtonText: 'OK'
            });
            </text>
        }
    </script>
}