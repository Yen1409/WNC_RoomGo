@model IEnumerable<Listing>
@{
    ViewData["Title"] = "Tin đăng của tôi";
    var isAdmin = User.IsInRole("Admin");
    var isOwner = User.IsInRole("Owner");
    var userId = Context.Session.GetInt32("UserId") ?? 0;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">📋 @(isAdmin ? "Quản lý tin đăng" : "Tin đăng của tôi")</h1>
            <p class="text-muted small">
                @(isAdmin ? "Tất cả tin được đăng trên hệ thống" : "Tất cả tin đăng của bạn")
            </p>
        </div>
        @if (isOwner)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Đăng tin mới
            </a>
        }
    </div>

    <div id="notification-area"></div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="display-1 text-muted">🏠</div>
            <h3 class="text-muted">@(isAdmin ? "Chưa có tin đăng nào" : "Bạn chưa có tin đăng nào")</h3>
            <p class="text-muted">@(isAdmin ? "Hệ thống chưa có tin đăng nào" : "Hãy đăng tin đầu tiên để tìm người thuê phòng!")</p>
            @if (isOwner)
            {
                <a asp-action="Create" class="btn btn-primary mt-3">Đăng tin ngay</a>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40px;">#</th>
                        <th style="width: 60px;">Ảnh</th>
                        <th>Tiêu đề</th>
                        <th style="width: 150px;">Giá</th>
                        <th style="width: 150px;">Trạng thái</th>
                        <th style="width: 200px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int index = 1; }
                    @foreach (var x in Model)
                    {
                        // XỬ LÝ ẢNH
                        var imageUrl = "/images/rooms/default-room.svg";
                        if (x.Images != null && x.Images.Count > 0)
                        {
                            var img = x.Images.FirstOrDefault();
                            if (img != null && !string.IsNullOrEmpty(img.Url))
                            {
                                imageUrl = img.Url.StartsWith("/") ? img.Url : $"/{img.Url.TrimStart('~', '/')}";
                            }
                        }

                        // XỬ LÝ TRẠNG THÁI
                        var statusColor = x.Status switch
                        {
                            ListingStatus.Pending => "warning",
                            ListingStatus.Approved => "success",
                            ListingStatus.Rejected => "danger",
                            ListingStatus.Hidden => "secondary",
                            _ => "secondary"
                        };
                        
                        var statusText = x.Status switch
                        {
                            ListingStatus.Pending => "⏳ Chờ duyệt",
                            ListingStatus.Approved => "✅ Đã duyệt",
                            ListingStatus.Rejected => "❌ Từ chối",
                            ListingStatus.Hidden => "👁️ Đã ẩn",
                            _ => x.Status.ToString()
                        };

                        <tr id="row-@x.Id">
                            <td class="text-center">@index</td>
                            <td>
                                <img src="@imageUrl" alt="@x.Title" 
                                    class="rounded" 
                                    style="width: 50px; height: 50px; object-fit: cover;" 
                                    onerror="this.onerror=null; this.src='/images/rooms/default-room.svg'" />
                            </td>
                            <td>
                                <div>
                                    <a asp-action="Detail" asp-controller="Home" asp-route-id="@x.Id" 
                                       class="text-decoration-none fw-semibold text-dark">
                                        @x.Title
                                    </a>
                                </div>
                                <div class="text-muted small">📍 @x.Address, @x.District</div>
                                <div class="text-muted small">👤 Chủ trọ: @x.Owner?.FullName</div>
                                @if (x.Status == ListingStatus.Rejected && !string.IsNullOrEmpty(x.RejectionReason))
                                {
                                    <div class="text-danger small mt-1">
                                        <i class="bi bi-info-circle"></i> @x.RejectionReason
                                    </div>
                                }
                            </td>
                            <td>
                                <span class="fw-bold">@x.Price.ToString("N0") đ</span>
                                <div class="text-muted small">@x.Area m²</div>
                            </td>
                            <td>
                                <span class="badge bg-@statusColor">@statusText</span>
                            </td>
                            <td>
                                @if (isOwner && x.OwnerId == userId)
                                {
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@x.Id" 
                                           class="btn btn-outline-primary" title="Sửa">
                                            <i class="bi bi-pencil"></i> Sửa
                                        </a>
                                        
                                        <button type="button" class="btn @(x.Status == ListingStatus.Hidden ? "btn-outline-success" : "btn-outline-secondary")" 
                                                onclick="toggleListingVisibility(@x.Id, @(x.Status == ListingStatus.Hidden ? "true" : "false"))" 
                                                title="@(x.Status == ListingStatus.Hidden ? "Hiện" : "Ẩn")">
                                            <i class="bi @(x.Status == ListingStatus.Hidden ? "bi-eye" : "bi-eye-slash")"></i> 
                                            @(x.Status == ListingStatus.Hidden ? "Hiện" : "Ẩn")
                                        </button>
                                        
                                        <button type="button" class="btn btn-outline-danger" 
                                                onclick="deleteListing(@x.Id)" title="Xóa">
                                            <i class="bi bi-trash"></i> Xóa
                                        </button>
                                    </div>
                                }
                                else if (isAdmin)
                                {
                                    <span class="text-muted small">Chỉ duyệt tin</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Không có quyền</span>
                                }
                            </td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        // 1. HÀM HIỂN THỊ TOAST THÔNG BÁO 
        function showToast(message, type = 'success') {
            const colors = {
                success: '#28a745',
                danger: '#dc3545',
                warning: '#ffc107',
                info: '#17a2b8'
            };
            
            const toast = document.createElement('div');
            toast.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            toast.style.cssText = `
                top: 20px;
                right: 20px;
                z-index: 9999;
                min-width: 300px;
                max-width: 500px;
                box-shadow: 0 4px 6px rgba(0,0,0,0.1);
                border-left: 4px solid ${colors[type] || '#28a745'};
            `;
            toast.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            `;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.style.transition = 'opacity 0.5s';
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 500);
            }, 5000);
        }

        // 2. XÓA TIN 
        function deleteListing(id) {
            Swal.fire({
                title: 'Xác nhận xóa tin',
                html: `
                    <p style="font-size: 16px; color: #555;">
                        Bạn có chắc chắn muốn xóa tin đăng này?
                    </p>
                    <p style="font-size: 14px; color: #dc3545; font-weight: bold;">
                        Hành động này không thể hoàn tác!
                    </p>
                `,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Hủy bỏ',
                reverseButtons: true,
                showLoaderOnConfirm: true,
                allowOutsideClick: () => !Swal.isLoading(),
                preConfirm: () => {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]');
                    const tokenValue = token ? token.value : '';

                    return fetch(`/Listings/Delete/${id}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': tokenValue
                        },
                        credentials: 'same-origin'
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (!data.success) {
                            throw new Error(data.message || 'Có lỗi xảy ra khi xóa tin!');
                        }
                        return data;
                    })
                    .catch(error => {
                        Swal.showValidationMessage(error.message);
                        throw error;
                    });
                }
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    const data = result.value;
                    const row = document.getElementById(`row-${id}`);
                    if (row) {
                        row.style.transition = 'opacity 0.5s, transform 0.3s';
                        row.style.transform = 'scale(0.95)';
                        row.style.opacity = '0';
                        setTimeout(() => {
                            row.remove();
                            updateRowNumbers();
                            showToast(data.message || 'Xóa tin thành công!', 'success');
                        }, 400);
                    } else {
                        location.reload();
                    }
                }
            });
        }

        // 3. ẨN/HIỆN TIN 
        function toggleListingVisibility(id, isHidden) {
            const title = isHidden ? 'Hiện lại tin' : 'Ẩn tin';
            const icon = isHidden ? 'success' : 'warning';
            const confirmButtonColor = isHidden ? '#28a745' : '#ffc107';
            const confirmButtonText = isHidden ? 'Hiện lại' : 'Ẩn đi';
            
            const message = isHidden
                ? 'Tin đăng sẽ được hiện lại trên trang tìm kiếm.'
                : 'Tin đăng sẽ bị ẩn khỏi trang tìm kiếm.';

            Swal.fire({
                title: title,
                html: `
                    <p style="font-size: 16px; color: #555;">
                        Bạn có chắc chắn muốn ${isHidden ? 'hiện lại' : 'ẩn'} tin đăng này?
                    </p>
                    <p style="font-size: 14px; color: ${isHidden ? '#28a745' : '#ffc107'};">
                        ${isHidden ? 'Tin sẽ xuất hiện lại trên trang tìm kiếm.' : 'Tin sẽ bị ẩn khỏi trang tìm kiếm.'}
                    </p>
                `,
                icon: icon,
                showCancelButton: true,
                confirmButtonColor: confirmButtonColor,
                cancelButtonColor: '#6c757d',
                confirmButtonText: confirmButtonText,
                cancelButtonText: 'Hủy bỏ',
                reverseButtons: true,
                showLoaderOnConfirm: true,
                allowOutsideClick: () => !Swal.isLoading(),
                preConfirm: () => {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]');
                    const tokenValue = token ? token.value : '';

                    return fetch(`/Listings/Hide/${id}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': tokenValue
                        },
                        credentials: 'same-origin'
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (!data.success) {
                            throw new Error(data.message || 'Có lỗi xảy ra!');
                        }
                        return data;
                    })
                    .catch(error => {
                        Swal.showValidationMessage(error.message);
                        throw error;
                    });
                }
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    showToast(result.value.message || (isHidden ? 'Hiện tin thành công!' : 'Ẩn tin thành công!'), 'success');
                    setTimeout(() => location.reload(), 1000);
                }
            });
        }

        // 4. CẬP NHẬT SỐ THỨ TỰ
        function updateRowNumbers() {
            const rows = document.querySelectorAll('tbody tr');
            rows.forEach((row, index) => {
                const firstCell = row.querySelector('td:first-child');
                if (firstCell) {
                    firstCell.textContent = index + 1;
                }
            });
        }

        // 5. TỰ ĐỘNG ẨN THÔNG BÁO
        setTimeout(() => {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                alert.style.transition = 'opacity 0.5s';
                alert.style.opacity = '0';
                setTimeout(() => alert.remove(), 500);
            });
        }, 5000);
    </script>
}