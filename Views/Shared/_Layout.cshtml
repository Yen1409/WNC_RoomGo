<!doctype html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content="RoomGo Hà Nội - tìm phòng trọ an toàn, thông minh theo vị trí." />
    <title>@ViewData["Title"] - RoomGo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <nav class="navbar navbar-expand-lg roomgo-nav">
        <div class="container"><a class="navbar-brand" asp-controller="Home" asp-action="Index"><b><span>⌂</span>
                    Room<span>Go</span> Hà Nội</b></a><button class="navbar-toggler" data-bs-toggle="collapse"
                data-bs-target="#nav">☰</button>
            <div id="nav" class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Search">Tìm phòng</a>
                    </li>@if(User.Identity?.IsAuthenticated==true){<li class="nav-item"><a class="nav-link"
                            asp-controller="Account" asp-action="Upgrade">Xác thực chủ trọ</a></li>
                    @if(User.IsInRole("Owner")){<li class="nav-item"><a class="nav-link" asp-controller="Listings"
                            asp-action="Mine">Tin của tôi</a></li>}@if(User.IsInRole("Admin")){<li class="nav-item"><a
                            class="nav-link" asp-controller="Admin" asp-action="Dashboard">Quản trị</a></li>}<li
                        class="nav-item">
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Tài khoản
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                <form asp-controller="Account" asp-action="Profile" method="get">
                                    <button class="dropdown-item">Hồ sơ</button>
                                </form>
                                </li>
                                <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button class="dropdown-item">Đăng xuất</button>
                                </form>
                                </li>
                            </ul>
                        </div> 
                    </li>}else{<li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Đăng
                            nhập</a></li>
                    <li class="nav-item"><a class="btn nav-cta" asp-controller="Account" asp-action="Register">Đăng
                            ký</a></li>}
                </ul>
            </div>
        </div>
    </nav>
    <main>@if(TempData["Success"] is string s){<div class="container pt-3">
            <div class="alert alert-success">@s</div>
        </div>}@if(TempData["Error"] is string e){<div class="container pt-3">
            <div class="alert alert-danger">@e</div>
        </div>}@RenderBody()</main>
    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3">
                    <h2 class="footer-logo">⌂ Room<span>Go</span> Hà Nội</h2>
                    <p>Hệ thống tìm phòng trọ thông minh dành cho Hà Nội.</p>
                </div>
                <div class="col-6 col-md-3">
                    <h3>NGƯỜI THUÊ</h3><a asp-controller="Home" asp-action="Search">Tìm phòng trọ</a><a
                        asp-controller="Home" asp-action="Search">Tìm theo bản đồ</a><a href="#">Hướng dẫn</a>
                </div>
                <div class="col-6 col-md-3">
                    <h3>CHỦ TRỌ</h3><a asp-controller="Listings" asp-action="Create">Đăng tin phòng</a><a
                        asp-controller="Account" asp-action="Upgrade">Xác thực tài khoản</a><a asp-controller="Listings"
                        asp-action="Mine">Quản lý phòng</a>
                </div>
                <div class="col-6 col-md-3">
                    <h3>HỖ TRỢ</h3><a href="#">FAQ</a><a href="#">Liên hệ</a><a href="#">Chính sách bảo mật</a>
                </div>
            </div>
            <div class="footer-bottom"><span>© 2026 RoomGo Hà Nội. Bảo lưu mọi quyền.</span><span>Điều khoản
                    &nbsp;&nbsp; Bảo mật</span></div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", false)
</body>

</html>
